#!/bin/bash
# Script to backup dotfiles

# Copy only the managed portion; drop anything work scripts appended past the sentinel
sed '/^# ===== END MANAGED DOTFILES =====$/q' ~/.bash_profile > bash_profile
cp ~/.gitignore_global gitignore_global
cp ~/.gitconfig gitconfig
cp ~/.inputrc inputrc
cp ~/.vimrc vimrc
cp -r ~/.vim/ vim

